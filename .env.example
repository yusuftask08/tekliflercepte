# Used by docker-compose.yml. In Coolify, set these in the resource's
# Environment Variables tab instead of a committed .env file.

POSTGRES_USER=tekliflercepte
POSTGRES_PASSWORD=change-me
POSTGRES_DB=tekliflercepte

# Same value across the whole stack — see apps/api/.env.example for why.
JWT_SECRET=change-me

# Public URLs of the deployed web/panel apps (used for CORS + email links).
WEB_ORIGIN=https://tekliflercepte.com
PANEL_ORIGIN=https://panel.tekliflercepte.com

# What the browser calls to reach the API — usually the same as WEB_ORIGIN's
# API subdomain, e.g. https://api.tekliflercepte.com.
NEXT_PUBLIC_API_URL=https://api.tekliflercepte.com
NEXT_PUBLIC_SITE_URL=https://tekliflercepte.com

# Optional — see apps/api/.env.example.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Teklifler Cepte <bildirim@tekliflercepte.com>"

# One-time admin bootstrap — see packages/db/prisma/seed.js.
ADMIN_SEED_PHONE=05550000000
ADMIN_SEED_PASSWORD=
