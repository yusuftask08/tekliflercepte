PORT=4000
DATABASE_URL="postgresql://user:password@localhost:5432/tekliflercepte?schema=public"

# Must be the exact same value as apps/web/.env and apps/panel/.env — all
# three services verify the same session JWT, a mismatch breaks login
# silently (token "invalid" everywhere).
JWT_SECRET=change-me

WEB_ORIGIN=http://localhost:3002
PANEL_ORIGIN=http://localhost:3001

# Optional — without these, emails are logged to the console instead of sent
# (see apps/api/src/lib/mailer.js). Get a key at https://resend.com after
# verifying your sending domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Teklifler Cepte <bildirim@tekliflercepte.com>"

# One-time admin bootstrap (packages/db/prisma/seed.js) — only used the
# first time the seed runs (i.e. when no user with this phone exists yet).
# If unset, a random password is generated and printed to the seed log once.
ADMIN_SEED_PHONE=05550000000
ADMIN_SEED_PASSWORD=
