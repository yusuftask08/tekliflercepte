{
  "name": "tekliflercepte",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @tekliflercepte/db exec prisma generate",
    "db:migrate": "pnpm --filter @tekliflercepte/db exec prisma migrate dev"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  }
}
